/* pages/feedback/feedback.wxss */
.feedback-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0;
  color: white;
}

.back-btn {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50rpx;
}

.back-icon {
  margin-right: 10rpx;
  font-weight: bold;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

/* 成功消息 */
.success-message {
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  margin-top: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

.success-icon {
  width: 100rpx;
  height: 100rpx;
  background: #52c41a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: white;
  margin: 0 auto 30rpx;
}

.success-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.success-hint {
  font-size: 28rpx;
  color: #666;
}

/* 表单容器 */
.form-container {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-top: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

/* 表单组 */
.form-group {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* 类型选择器 */
.type-picker {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

/* 反馈内容文本域 */
.feedback-textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 联系方式输入框 */
.contact-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 20rpx;
  margin: 40rpx 0;
}

.clear-btn {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.clear-btn[disabled] {
  opacity: 0.5;
}

.submit-btn {
  flex: 2;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 提示信息 */
.tips {
  background: #f0f8ff;
  border-radius: 12rpx;
  padding: 30rpx;
  border-left: 6rpx solid #1890ff;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  color: #1890ff;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.tip-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  line-height: 1.4;
}