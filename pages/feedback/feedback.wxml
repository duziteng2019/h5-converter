<!--pages/feedback/feedback.wxml-->
<view class="feedback-page">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="onBack">
      <text class="back-icon">←</text>
      <text>返回</text>
    </view>
    <text class="title">用户反馈</text>
  </view>

  <!-- 提交成功提示 -->
  <view class="success-message" wx:if="{{submitSuccess}}">
    <view class="success-icon">✓</view>
    <text class="success-text">反馈提交成功！感谢您的宝贵意见</text>
    <text class="success-hint">3秒后自动返回</text>
  </view>

  <!-- 反馈表单 -->
  <view class="form-container" wx:if="{{!submitSuccess}}">
    <!-- 反馈类型 -->
    <view class="form-group">
      <text class="label">反馈类型</text>
      <picker 
        class="type-picker" 
        range="{{pickerRange}}" 
        value="{{pickerValue}}"
        bindchange="onTypeChange">
        <view class="picker-value">
          {{pickerRange[pickerValue]}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 反馈内容 -->
    <view class="form-group">
      <text class="label">反馈内容</text>
      <textarea 
        class="feedback-textarea" 
        placeholder="请详细描述您遇到的问题或建议..."
        maxlength="500"
        value="{{feedback}}"
        bindinput="onFeedbackInput"
        show-confirm-bar="{{false}}">
      </textarea>
      <text class="char-count">{{feedback.length}}/500</text>
    </view>

    <!-- 联系方式 -->
    <view class="form-group">
      <text class="label">联系方式（选填）</text>
      <input 
        class="contact-input" 
        placeholder="微信/手机号/邮箱"
        value="{{contact}}"
        bindinput="onContactInput" />
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button 
        class="clear-btn" 
        bindtap="onClear"
        disabled="{{submitting}}">
        清空
      </button>
      <button 
        class="submit-btn" 
        bindtap="onSubmit"
        disabled="{{submitting || !feedback}}"
        loading="{{submitting}}">
        {{submitting ? '提交中...' : '提交反馈'}}
      </button>
    </view>

    <!-- 使用提示 -->
    <view class="tips">
      <text class="tip-title">📝 反馈提示</text>
      <text class="tip-item">• 详细描述问题，方便我们快速定位</text>
      <text class="tip-item">• 留下联系方式，便于问题跟进</text>
      <text class="tip-item">• 您的反馈将帮助我们改进产品</text>
    </view>
  </view>
</view>