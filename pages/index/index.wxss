/**index.wxss**/
.container {
  background-color: #f8f9fa;
  min-height: 100vh;
}



/* 搜索栏样式 */
.search-container {
  padding: 20rpx 30rpx;
  background: white;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 15rpx 25rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.search-box:focus-within {
  border-color: #8a2be2;
  background: white;
  box-shadow: 0 4rpx 20rpx rgba(138, 43, 226, 0.1);
}

.search-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  font-size: 28rpx;
  color: #8a2be2;
  margin-left: 15rpx;
}

/* 筛选标签样式 */
.filter-container {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-tag {
  padding: 12rpx 24rpx;
  background: #f8f9fa;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.filter-tag.active {
  background: linear-gradient(135deg, #8a2be2 0%, #9370db 100%);
  color: white;
  transform: scale(1.05);
  box-shadow: 0 4rpx 15rpx rgba(138, 43, 226, 0.3);
}

/* 列表容器 */
.hall-list {
  height: calc(100vh - 360rpx);
  padding: 16rpx 0;
}

/* 卡片式舞厅设计 */
.dance-card {
  width: 90%;
  margin: 16rpx auto;
  padding: 32rpx 24rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.06);
  border: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.dance-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(135deg, #8a2be2 0%, #9370db 100%);
}

.dance-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

/* 舞厅名称 + 评分行 */
.name-rating-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.dance-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.3;
  flex: 1;
}

/* 评分徽章 */
.rating-badge {
  display: flex;
  align-items: center;
  background: rgba(255, 167, 38, 0.1);
  border-radius: 20rpx;
  padding: 6rpx 12rpx;
  margin-left: 16rpx;
}

.rating-star {
  font-size: 26rpx;
  color: #ffa726;
  margin-right: 4rpx;
}

.rating-value {
  font-size: 26rpx;
  color: #ffa726;
  font-weight: bold;
}

/* 信息项容器 */
.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 6rpx 0;
}

.info-item:last-child {
  margin-bottom: 0;
}

/* 图标样式 */
.info-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
  width: 36rpx;
  text-align: center;
}

.location-icon {
  color: #FFB6C1;
}

/* 信息文字 */
.info-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  flex: 1;
}

.info-text.address {
  color: #FFB6C1;
  font-weight: 500;
}

/* 距离信息 */
.distance-text {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
  font-weight: normal;
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 回到顶部按钮 */
.back-to-top {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #8a2be2 0%, #9370db 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 25rpx rgba(138, 43, 226, 0.4);
  z-index: 999;
  transition: all 0.3s ease;
}

.back-to-top:active {
  transform: scale(0.9);
}

.back-icon {
  color: white;
  font-size: 36rpx;
  font-weight: bold;
}

/* 骨架屏样式 */
.skeleton {
  background: #f8f9fa;
  border: 1rpx solid #f0f0f0;
  width: 90%;
  margin: 16rpx auto;
  padding: 32rpx 24rpx;
  border-radius: 20rpx;
}

/* 名称+评分骨架屏布局 */
.skeleton-name-rating {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.skeleton-title {
  height: 34rpx;
  width: 60%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 8rpx;
}

.skeleton-rating {
  height: 26rpx;
  width: 50rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-info {
  height: 26rpx;
  width: 80%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
}

.skeleton-info:last-child {
  width: 70%;
  margin-bottom: 0;
}

@keyframes loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 加载更多状态样式 */
.loading-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin: 20rpx 0;
  border: 1px solid #e0e0e0;
}

.loading-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  animation: spin 1s infinite linear;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

.no-more-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background: #f0f8f0;
  border-radius: 16rpx;
  margin: 20rpx 0;
  border: 1px solid #d0e8d0;
}

.no-more-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.no-more-text {
  font-size: 28rpx;
  color: #4caf50;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 搜索历史面板样式 */
.search-history-panel {
  position: absolute;
  top: 100%;
  left: 30rpx;
  right: 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  margin-top: 10rpx;
  z-index: 1000;
  max-height: 500rpx;
  overflow-y: auto;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.clear-history {
  font-size: 24rpx;
  color: #8a2be2;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #f8f0ff;
}

.history-list {
  padding: 0 30rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f9fa;
}

.history-item:last-child {
  border-bottom: none;
}

.history-icon {
  font-size: 24rpx;
  color: #8a2be2;
  margin-right: 16rpx;
}

.history-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.empty-history {
  text-align: center;
  padding: 60rpx 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 搜索建议面板样式 */
.search-suggestions-panel {
  position: absolute;
  top: 100%;
  left: 30rpx;
  right: 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  margin-top: 10rpx;
  z-index: 1000;
  max-height: 400rpx;
  overflow-y: auto;
}

.suggestions-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 30rpx 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.suggestions-list {
  padding: 0 30rpx;
}

.suggestion-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f9fa;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.suggestion-address {
  font-size: 22rpx;
  color: #999;
}

/* 清除按钮样式 */
.clear-btn {
  font-size: 28rpx;
  color: #999;
  margin-left: 15rpx;
  padding: 8rpx;
  border-radius: 50%;
  background: #f0f0f0;
}