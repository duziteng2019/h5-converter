<!--index.wxml-->
<view class="container">

  <!-- 顶部搜索栏 -->
  <view class="search-container">
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="搜索舞厅名称或地址" 
        value="{{searchText}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
      />
      <view wx:if="{{searchText}}" class="clear-btn" bindtap="onClearSearch">✕</view>
      <view wx:else class="search-btn">🔍</view>
    </view>
    
    <!-- 搜索历史面板 -->
    <view wx:if="{{showSearchHistory}}" class="search-history-panel">
      <view class="history-header">
        <text class="history-title">搜索历史</text>
        <text wx:if="{{searchHistory.length > 0}}" class="clear-history" bindtap="clearSearchHistory">清空</text>
      </view>
      <view wx:if="{{searchHistory.length > 0}}" class="history-list">
        <view 
          wx:for="{{searchHistory}}" 
          wx:key="*this" 
          class="history-item"
          bindtap="onHistoryItemTap"
          data-keyword="{{item}}"
        >
          <text class="history-icon">🔍</text>
          <text class="history-text">{{item}}</text>
        </view>
      </view>
      <view wx:else class="empty-history">
        <text>暂无搜索历史</text>
      </view>
    </view>
    
    <!-- 搜索建议面板 -->
    <view wx:if="{{searchSuggestions.length > 0 && !showSearchHistory}}" class="search-suggestions-panel">
      <view class="suggestions-title">搜索结果</view>
      <view class="suggestions-list">
        <view 
          wx:for="{{searchSuggestions}}" 
          wx:key="name" 
          class="suggestion-item"
          bindtap="onSuggestionItemTap"
          data-suggestion="{{item}}"
        >
          <text class="suggestion-name">{{item.name}}</text>
          <text class="suggestion-address">{{item.address}} · {{item.city}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-container">
    <view 
      wx:for="{{filterOptions}}" 
      wx:key="index"
      class="filter-tag {{activeFilter === index ? 'active' : ''}}"
      bindtap="onFilterTap"
      data-index="{{index}}"
    >
      {{item}}
    </view>
  </view>

  <!-- 舞厅列表 -->
  <scroll-view 
    class="hall-list" 
    scroll-y="true"
    scroll-top="{{scrollTop}}"
    bindscroll="onScroll"
    enhanced="true"
    show-scrollbar="false"
  >
    <!-- 数据加载状态 - 骨架屏 -->
    <block wx:if="{{isLoading}}">
      <view class="dance-card skeleton">
        <view class="skeleton-name-rating">
          <view class="skeleton-title"></view>
          <view class="skeleton-rating"></view>
        </view>
        <view class="skeleton-info"></view>
        <view class="skeleton-info"></view>
      </view>
      <view class="dance-card skeleton">
        <view class="skeleton-name-rating">
          <view class="skeleton-title"></view>
          <view class="skeleton-rating"></view>
        </view>
        <view class="skeleton-info"></view>
        <view class="skeleton-info"></view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <block wx:elif="{{filteredHalls.length === 0}}">
      <view class="empty-state">
        <text class="empty-icon">🎭</text>
        <text class="empty-text">暂无舞厅信息，敬请期待～</text>
      </view>
    </block>
    
    <!-- 数据渲染 - 卡片式设计 -->
    <block wx:else>
      <view 
        wx:for="{{filteredHalls}}" 
        wx:key="_id" 
        class="dance-card"
        bindtap="navigateToDetail"
        data-index="{{index}}"
      >
        <!-- 舞厅名称 + 评分 -->
        <view class="name-rating-row">
          <text class="dance-name">{{item.name || '舞厅名称待补充'}}</text>
          <view class="rating-badge" wx:if="{{item.rating}}">
            <text class="rating-star">★</text>
            <text class="rating-value">{{item.rating}}</text>
          </view>
        </view>
        
        <!-- 营业时间 + 图标 -->
        <view class="info-item">
          <text class="info-icon">🕐</text>
          <text class="info-text">{{item.businessHours || '营业时间暂未更新~'}}</text>
        </view>
        
        <!-- 地址 + 距离 -->
        <view class="info-item">
          <text class="info-icon location-icon">📍</text>
          <text class="info-text address">{{item.address || '地址待补充'}}</text>
          <text class="distance-text" wx:if="{{item.distanceText !== '距离未知'}}"> · {{item.distanceText}}</text>
        </view>
      </view>
      
      <!-- 加载更多状态提示 -->
      <view wx:if="{{loadingMore}}" class="loading-more">
        <text class="loading-icon">⏳</text>
        <text class="loading-text">正在加载更多数据...</text>
      </view>
      
      <view wx:if="{{!hasMore && filteredHalls.length > 0}}" class="no-more-data">
        <text class="no-more-icon">✅</text>
        <text class="no-more-text">已加载全部数据</text>
      </view>
    </block>
  </scroll-view>

  <!-- 回到顶部按钮 -->
  <view 
    wx:if="{{showBackToTop}}" 
    class="back-to-top"
    bindtap="backToTop"
  >
    <text class="back-icon">↑</text>
  </view>
</view>

