/* 优化后的首页样式 - 现代UI设计 */

/* 重置页面样式 */
page {
  background: var(--bg-primary);
  min-height: 100vh;
}

/* 顶部导航栏 - 现代化设计 */
.top-nav {
  background: var(--primary-gradient);
  padding: var(--space-6) var(--space-4) var(--space-10);
  position: relative;
  z-index: 10;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-title-section {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.logo {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 24rpx;
}

.nav-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: white;
  letter-spacing: -0.5rpx;
}

.nav-actions {
  display: flex;
  gap: var(--space-2);
}

.btn-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition-normal);
}

.btn-icon:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.btn-icon .icon {
  width: 20rpx;
  height: 20rpx;
  color: white;
}

/* 搜索栏 - 现代化设计 */
.search-section {
  margin: -24rpx var(--space-4) var(--space-6);
  position: relative;
  z-index: 20;
}

.search-container {
  background: var(--bg-secondary);
  border-radius: var(--radius-xl);
  padding: var(--space-2);
  box-shadow: var(--shadow-lg);
  border: 1rpx solid var(--border-light);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: var(--space-3) var(--space-4);
  transition: var(--transition-normal);
}

.search-input-wrapper:focus-within {
  box-shadow: inset 0 0 0 2rpx var(--primary-color);
}

.search-icon {
  width: 20rpx;
  height: 20rpx;
  color: var(--text-tertiary);
  margin-right: var(--space-2);
}

.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  background: transparent;
  border: none;
  height: 40rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.search-input::placeholder {
  color: var(--text-tertiary);
  font-weight: 400;
}

.btn-clear {
  width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-full);
  background: var(--text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--space-2);
}

.clear-icon {
  font-size: 16rpx;
  color: white;
  font-weight: 600;
}

/* 快速筛选 - 现代化设计 */
.quick-filters {
  margin: 0 var(--space-4) var(--space-6);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  gap: var(--space-2);
}

.filter-tag {
  background: var(--bg-secondary);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-4);
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  white-space: nowrap;
  font-weight: 500;
  transition: var(--transition-normal);
}

.filter-tag.active {
  background: var(--primary-gradient);
  color: white;
  border-color: var(--primary-color);
  box-shadow: var(--shadow-md);
}

/* 内容区域 */
.content-section {
  padding: 0 var(--space-4) var(--space-12);
}

/* 加载状态 - 现代化设计 */
.loading-state {
  padding: var(--space-4) 0;
}

.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
}

.skeleton-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1rpx solid var(--border-light);
}

.skeleton-image {
  width: 100%;
  height: 180rpx;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

.skeleton-content {
  padding: var(--space-4);
}

.skeleton-line {
  height: 16rpx;
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-2);
}

.skeleton-line.long {
  width: 80%;
}

.skeleton-line.medium {
  width: 60%;
}

.skeleton-line.short {
  width: 40%;
}

/* 空状态 - 现代化设计 */
.empty-state {
  text-align: center;
  padding: var(--space-12) var(--space-4);
}

.empty-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-full);
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-4);
}

.empty-icon {
  font-size: 48rpx;
  opacity: 0.7;
}

.empty-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
  letter-spacing: -0.5rpx;
}

.empty-subtitle {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-6);
  line-height: 1.5;
}

.empty-actions {
  display: flex;
  gap: var(--space-3);
  justify-content: center;
}

/* 舞厅网格 - 现代化设计 */
.hall-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
}

.hall-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-xl);
  overflow: hidden;
  position: relative;
  border: 1rpx solid var(--border-light);
}

.card-hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
  border-color: var(--border-color);
}

/* 卡片媒体区域 */
.card-media {
  position: relative;
}

.card-image {
  width: 100%;
  height: 180rpx;
  object-fit: cover;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

.rating-badge {
  position: absolute;
  top: var(--space-2);
  left: var(--space-2);
  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  gap: 2rpx;
  font-size: var(--font-size-xs);
  font-weight: 600;
  backdrop-filter: blur(10rpx);
}

.rating-icon {
  width: 12rpx;
  height: 12rpx;
  color: #ffd700;
}

.favorite-btn {
  position: absolute;
  top: var(--space-2);
  right: var(--space-2);
  width: 36rpx;
  height: 36rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.95);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition-normal);
  backdrop-filter: blur(10rpx);
}

.favorite-btn.active {
  background: var(--error-color);
}

.favorite-btn.active .favorite-icon {
  color: white;
}

.favorite-icon {
  width: 16rpx;
  height: 16rpx;
  color: var(--text-tertiary);
}

/* 卡片内容 */
.card-body {
  padding: var(--space-4);
}

.hall-name {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  letter-spacing: -0.3rpx;
}

.hall-info {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-4);
  gap: var(--space-1);
}

.location-icon {
  width: 16rpx;
  height: 16rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.hall-address {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hall-tags {
  display: flex;
  gap: var(--space-1);
}

.tag {
  font-size: var(--font-size-xs);
  padding: 2rpx var(--space-2);
  border-radius: var(--radius-sm);
  font-weight: 600;
}

.tag.new-tag {
  background: var(--success-color);
  color: white;
}

.tag.discount-tag {
  background: var(--warning-color);
  color: white;
}

.btn-detail {
  background: var(--primary-gradient);
  color: white;
  border: none;
  border-radius: var(--radius-md);
  padding: var(--space-2) var(--space-3);
  font-size: var(--font-size-xs);
  font-weight: 600;
  white-space: nowrap;
}

/* 回到顶部 */
.back-to-top {
  position: fixed;
  bottom: var(--space-8);
  right: var(--space-4);
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-full);
  background: var(--primary-gradient);
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.back-icon {
  font-size: 20rpx;
  color: white;
  font-weight: 600;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .hall-grid {
    grid-template-columns: 1fr;
  }
  
  .empty-actions {
    flex-direction: column;
  }
  
  .nav-title {
    font-size: var(--font-size-lg);
  }
}

/* 动画效果 */
.fade-in-up {
  animation: fadeInUp 0.6s ease-out;
}

.scale-in {
  animation: scaleIn 0.4s ease-out;
}

.loading-shimmer {
  background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%);
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}