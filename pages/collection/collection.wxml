<!-- 收藏页面 - 多巴胺设计风格统一 -->

<view class="collection-container">
  <!-- 页面头部 - 多巴胺风格 -->
  <view class="header">
    <view class="header-content">
      <text class="title">我的收藏</text>
      <text wx:if="{{collections.length > 0}}" class="count">{{collections.length}}</text>
    </view>
    <view class="header-actions">
      <button wx:if="{{collections.length > 0}}" class="btn-clear" bindtap="clearAllCollections">清空全部</button>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-container">
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="搜索收藏舞厅" 
        value="{{searchText}}"
        bindinput="onSearchInput"
      />
      <view class="search-btn">🔍</view>
    </view>
  </view>

  <!-- 收藏列表 -->
  <view class="collection-list">
    <view wx:for="{{collections}}" wx:key="_id" class="collection-item animate-slideInLeft">
      <!-- 图片 -->
      <image 
        src="{{item.image}}" 
        class="item-image" 
        mode="aspectFill" 
        lazy-load="true" 
        binderror="onImageError" 
        data-index="{{index}}"
      />
      
      <!-- 内容区域 -->
      <view class="item-content">
        <text class="item-name">{{item.name}}</text>
        
        <view class="item-info">
          <text class="location-icon">📍</text>
          <text class="item-address">{{item.address}}</text>
        </view>
        
        <view class="item-meta">
          <text wx:if="{{item.rating}}" class="rating">⭐ {{item.rating}}</text>
          <text class="collect-time">收藏于 {{item.collectTime}}</text>
        </view>
      </view>
      
      <!-- 操作按钮 -->
      <view class="item-actions">
        <button class="btn-detail" bindtap="goToDetail" data-id="{{item._id}}">
          查看详情
        </button>
        <button class="btn-remove" bindtap="deleteCollection" data-id="{{item._id}}">
          取消收藏
        </button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && collections.length === 0}}" class="empty-state">
    <text class="empty-icon">💖</text>
    <text class="empty-title">暂无收藏</text>
    <text class="empty-subtitle">去首页发现更多舞厅吧</text>
    <button class="btn-primary" bindtap="goToIndex">去首页逛逛</button>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-shimmer" wx:for="{{[1,2,3]}}" wx:key="index">
      <view class="shimmer-image"></view>
      <view class="shimmer-text"></view>
      <view class="shimmer-text short"></view>
    </view>
  </view>
</view>