/* ===== 多巴胺风格设计系统 v3.0 ===== */
/* 鲜艳色彩、圆角设计、渐变效果、愉悦动感 */

/* 多巴胺色彩方案 */
:root {
  /* 主色调 - 鲜艳活泼 */
  --dopamine-purple: #8B5CF6;          /* 活力紫色 */
  --dopamine-pink: #EC4899;             /* 热情粉色 */
  --dopamine-orange: #F97316;            /* 温暖橙色 */
  --dopamine-cyan: #06B6D4;             /* 清新青色 */
  --dopamine-green: #10B981;            /* 生机绿色 */
  --dopamine-yellow: #F59E0B;           /* 快乐黄色 */
  
  /* 渐变背景 - 多巴胺风格 */
  --gradient-primary: linear-gradient(135deg, var(--dopamine-purple), var(--dopamine-pink));
  --gradient-secondary: linear-gradient(135deg, var(--dopamine-orange), var(--dopamine-yellow));
  --gradient-success: linear-gradient(135deg, var(--dopamine-green), var(--dopamine-cyan));
  --gradient-warning: linear-gradient(135deg, var(--dopamine-yellow), var(--dopamine-orange));
  
  /* 中性色 - 保持平衡 */
  --text-primary: #1F2937;              /* 深灰黑 */
  --text-secondary: #6B7280;             /* 中灰 */
  --text-tertiary: #9CA3AF;              /* 浅灰 */
  --bg-primary: #FAFAFA;                 /* 极浅灰 */
  --bg-secondary: #FFFFFF;               /* 纯白 */
  --bg-tertiary: #F3F4F6;                /* 浅灰背景 */
  --border-color: #E5E7EB;               /* 边框色 */
  
  /* 超大圆角系统 - 多巴胺特色 */
  --radius-xs: 8rpx;
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --radius-2xl: 64rpx;
  --radius-3xl: 96rpx;
  --radius-full: 9999rpx;
  
  /* 间距系统 */
  --space-1: 4rpx;
  --space-2: 8rpx;
  --space-3: 12rpx;
  --space-4: 16rpx;
  --space-5: 20rpx;
  --space-6: 24rpx;
  --space-8: 32rpx;
  --space-10: 40rpx;
  --space-12: 48rpx;
  --space-16: 64rpx;
  --space-20: 80rpx;
  
  /* 字体系统 */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-2xl: 40rpx;
  --font-size-3xl: 48rpx;
  --font-size-4xl: 56rpx;
  
  /* 动效系统 */
  --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-normal: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  
  /* 阴影系统 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  --shadow-xl: 0 16rpx 64rpx rgba(0, 0, 0, 0.2);
}

/* 全局样式重置 */
page {
  background: var(--bg-primary);
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, 'Microsoft YaHei', -apple-system, sans-serif;
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 通用容器 */
.container {
  padding: 0 var(--space-4);
  max-width: 750rpx;
  margin: 0 auto;
}

/* 多巴胺卡片样式 */
.card {
  background: var(--bg-secondary);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--space-4);
  border: 1rpx solid var(--border-color);
  transition: all var(--transition-normal);
}

.card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-4rpx);
}

/* 多巴胺按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4) var(--space-6);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-base);
  font-weight: 600;
  transition: all var(--transition-fast);
  border: none;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: all var(--transition-slow);
}

.btn:hover::before {
  left: 100%;
}

.btn-primary {
  background: var(--gradient-primary);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.3);
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(139, 92, 246, 0.4);
}

.btn-secondary {
  background: var(--bg-tertiary);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}

.btn-secondary:active {
  background: var(--border-color);
}

/* 文本样式 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }

/* 标题样式 */
.title-lg {
  font-size: var(--font-size-3xl);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  letter-spacing: -0.5rpx;
}

.title-md {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.title-sm {
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--space-1);
}

/* 布局工具类 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.text-center { text-align: center; }

/* 间距工具类 */
.mt-1 { margin-top: var(--space-1); }
.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }

.mb-1 { margin-bottom: var(--space-1); }
.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }

.p-1 { padding: var(--space-1); }
.p-2 { padding: var(--space-2); }
.p-3 { padding: var(--space-3); }
.p-4 { padding: var(--space-4); }

/* 多巴胺动画 */
@keyframes bounce {
  0%, 20%, 53%, 80%, 100% {
    transform: translate3d(0,0,0);
  }
  40%, 43% {
    transform: translate3d(0,-8rpx,0);
  }
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.animate-bounce {
  animation: bounce 2s infinite;
}

.animate-pulse {
  animation: pulse 2s infinite;
}

.animate-slideInUp {
  animation: slideInUp var(--transition-normal);
}

.animate-fadeIn {
  animation: fadeIn var(--transition-normal);
}

/* 响应式设计 */
@media (max-width: 480px) {
  .container {
    padding: 0 var(--space-3);
  }
  
  .card {
    padding: var(--space-4);
    border-radius: var(--radius-lg);
  }
}

/* 彩色边框装饰 */
.border-gradient {
  border: 2rpx solid;
  border-image: var(--gradient-primary) 1;
}

/* 多彩标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 600;
  color: white;
  white-space: nowrap;
}

.tag-purple {
  background: var(--dopamine-purple);
}

.tag-pink {
  background: var(--dopamine-pink);
}

.tag-orange {
  background: var(--dopamine-orange);
}

.tag-cyan {
  background: var(--dopamine-cyan);
}

.tag-green {
  background: var(--dopamine-green);
}

.tag-yellow {
  background: var(--dopamine-yellow);
}